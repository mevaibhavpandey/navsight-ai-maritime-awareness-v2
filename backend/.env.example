# ── AIS Configuration ──────────────────────────────────────────────────────
AIS_PROVIDER=aisstream
AIS_API_KEY=your_aisstream_api_key_here

# ── Weather API ─────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500,null

# Broadcast interval seconds (how often backend pushes to frontend)
POLL_INTERVAL=3

# Max vessels in memory
MAX_VESSELS=8000
